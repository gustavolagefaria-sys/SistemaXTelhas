# ─── Banco de Dados (Neon.tech) ───────────────────────────────────────────────
# URL com connection pooling — usada pela aplicação em produção
# Formato: postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/xtelhas?sslmode=require&pgbouncer=true"

# URL direta (sem pooler) — usada pelo Prisma para migrações e introspection
# Mesmo host, sem &pgbouncer=true
DIRECT_URL="postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/xtelhas?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Segredo para assinar os tokens JWT. Use um valor longo e aleatório em produção.
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-uma-chave-secreta-longa-e-aleatoria"

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
